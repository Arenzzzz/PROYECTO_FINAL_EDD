digraph ListaImagenes {
    rankdir=LR;
    node [shape=record, style=filled, fillcolor="#2980b9", fontcolor=white];
    img1 [label="{Imagen 1 | Capas: 2, 3}"];
    img2 [label="{Imagen 2 | Capas: 1, 3}"];
    img3 [label="{Imagen 3 | Capas: }"];
    img1 -> img2;
    img2 -> img3;
    img3 -> img1;
}
